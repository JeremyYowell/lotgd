# =============================================================================
# Legends of the Green Dollar — .gitignore
# =============================================================================

# -----------------------------------------------------------------------
# SECRETS — never commit these
# -----------------------------------------------------------------------
config/config.php

# -----------------------------------------------------------------------
# LOGS — runtime generated, never committed
# -----------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------
# OS / EDITOR FILES
# -----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------
# DEPENDENCY MANAGERS (if ever added)
# -----------------------------------------------------------------------
vendor/
node_modules/
composer.lock
package-lock.json

# -----------------------------------------------------------------------
# RUNTIME / TEMP
# -----------------------------------------------------------------------
*.tmp
*.cache
