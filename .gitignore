# =============================================================================
# Legends of the Green Dollar — .gitignore
# =============================================================================

# -----------------------------------------------------------------------
# SECRETS — never commit these
# -----------------------------------------------------------------------
config/config.php

# -----------------------------------------------------------------------
# LOGS — runtime generated
# -----------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------
# OS / EDITOR FILES
# -----------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------
# DEPENDENCY MANAGERS (if ever added)
# -----------------------------------------------------------------------
vendor/
node_modules/
composer.lock
package-lock.json

# -----------------------------------------------------------------------
# RUNTIME / TEMP
# -----------------------------------------------------------------------
*.tmp
*.cache

# -----------------------------------------------------------------------
# SETUP WIZARD
# The setup/ directory is included in the repo for first-time deployment.
# The wizard deletes itself on completion. If for some reason it wasn't
# deleted, do not re-commit it.
# -----------------------------------------------------------------------
setup/.installed
